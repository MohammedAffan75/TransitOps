generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  password     String   @db.VarChar(255)
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

model Vehicle {
  id                 Int           @id @default(autoincrement())
  registrationNumber String        @unique @map("registration_number") @db.VarChar(50)
  model              String        @db.VarChar(100)
  type               String        @db.VarChar(50)
  capacity           Decimal       @db.Decimal(10, 2) // Max Load Capacity in kg/tons
  odometer           Decimal       @db.Decimal(10, 2) // Current odometer reading
  acquisitionCost    Decimal       @map("acquisition_cost") @db.Decimal(15, 2) // Cost of the vehicle for ROI calculation
  status             VehicleStatus @default(AVAILABLE)
  region             String?       @db.VarChar(100) // For dashboard filtering
  documentUrl        String?       @map("document_url") @db.VarChar(255) // Bonus: Document Management

  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  expenses           Expense[]
  fuelLogs           FuelLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("vehicles")
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

model Driver {
  id              Int          @id @default(autoincrement())
  name            String       @db.VarChar(100)
  licenseNumber   String       @unique @map("license_number") @db.VarChar(50)
  licenseCategory String       @map("license_category") @db.VarChar(50)
  licenseExpiry   DateTime     @map("license_expiry") @db.Date
  contactNumber   String       @map("contact_number") @db.VarChar(20)
  safetyScore     Decimal?     @map("safety_score") @db.Decimal(5, 2)
  status          DriverStatus @default(AVAILABLE)
  documentUrl     String?      @map("document_url") @db.VarChar(255) // Bonus: Document Management

  // stats for UI "Trip Completion." metric
  totalTrips     Int @default(0) @map("total_trips")
  completedTrips Int @default(0) @map("completed_trips")

  trips Trip[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("drivers")
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

model Trip {
  id          Int      @id @default(autoincrement())
  source      String   @db.VarChar(255)
  destination String   @db.VarChar(255)
  cargoWeight Decimal  @map("cargo_weight") @db.Decimal(10, 2)
  distance    Decimal  @db.Decimal(10, 2) // Planned distance
  revenue     Decimal? @db.Decimal(12, 2) // Optional, needed for Vehicle ROI

  vehicleId Int     @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)

  driverId Int    @map("driver_id")
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Restrict)

  status TripStatus @default(DRAFT)

  expenses Expense[]
  fuelLogs FuelLog[]

  dispatchedAt DateTime? @map("dispatched_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@map("trips")
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model MaintenanceRecord {
  id          Int               @id @default(autoincrement())
  description String            @db.VarChar(255)
  cost        Decimal           @db.Decimal(10, 2)
  date        DateTime          @default(now()) @db.Date
  status      MaintenanceStatus @default(ACTIVE)

  vehicleId Int     @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@map("maintenance_records")
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}

model FuelLog {
  id     Int      @id @default(autoincrement())
  liters Decimal  @db.Decimal(10, 2)
  cost   Decimal  @db.Decimal(12, 2)
  date   DateTime @default(now()) @db.Date

  vehicleId Int     @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  tripId Int?  @map("trip_id")
  trip   Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([tripId])
  @@map("fuel_logs")
}

model Expense {
  id     Int         @id @default(autoincrement())
  type   ExpenseType
  amount Decimal     @db.Decimal(12, 2)
  date   DateTime    @default(now()) @db.Date

  vehicleId Int     @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  tripId Int?  @map("trip_id")
  trip   Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([tripId])
  @@map("expenses")
}

enum ExpenseType {
  TOLL
  MAINTENANCE
  OTHER
}
